# OpenWebPanel Environment Configuration
# Copy this file to .env and adjust values for your deployment

# Database (SQLite)
OWP_DB_PATH=./openwebpanel.db

# JWT Secret — CHANGE THIS in production
OWP_JWT_SECRET=change-this-to-a-random-secret-string

# Home directories base (where user accounts live)
OWP_HOMES_BASE=./homes/

# Static frontend files (built SPA)
OWP_STATIC_DIR=./web/dist

# Listen address for the API backend
OWP_LISTEN=:9000

# Public host (used for URL generation)
OWP_PUBLIC_HOST=your-server-ip:9000

# Shared IP address of the server
OWP_SHARED_IP=your-server-ip

# phpMyAdmin backend URL
OWP_PHPMYADMIN_PORT=http://127.0.0.1:8080

# SMTP server port
OWP_SMTP_PORT=2525

# Nginx paths (for auto-generated vhosts)
NGINX_PREFIX=/etc/nginx
NGINX_VHOST_DIR=/etc/nginx/vhosts
NGINX_BIN=/usr/sbin/nginx
NGINX_CONF=/etc/nginx/nginx.conf
NGINX_LOG_DIR=/var/log/nginx

# PHP-FPM socket
PHP_FPM_SOCKET=/run/php/php8.3-fpm.sock

# MySQL/MariaDB (for user hosting databases)
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_ADMIN_PASSWORD=your-mysql-admin-password
