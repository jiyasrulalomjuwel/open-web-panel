{
  "name": "openwebpanel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:child": "vite --config vite.child.config.ts",
    "build": "tsc && vite build",
    "build:admin": "tsc && vite build --config vite.admin.config.ts",
    "build:child": "tsc && vite build --config vite.child.config.ts",
    "build:all": "npm run build:admin && npm run build:child",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/react-joyride": "^2.0.5",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-joyride": "^3.1.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.9.3",
    "vite": "^5.4.0"
  }
}
